import java.io.*;

public class FileCopy {
    public static void main(String[] args) {
        String src  = "source.txt";
        String dest = "destination.txt";

        // Create source file first
        try (FileWriter fw = new FileWriter(src)) {
            fw.write("This is the source file content.\nLine 2.\nLine 3.");
        } catch (IOException e) { e.printStackTrace(); }

        // Copy using streams
        try (FileInputStream  fis = new FileInputStream(src);
             FileOutputStream fos = new FileOutputStream(dest)) {

            byte[] buffer = new byte[1024];
            int    bytesRead;

            while ((bytesRead = fis.read(buffer)) != -1) {
                fos.write(buffer, 0, bytesRead);
            }

            System.out.println("File copied successfully from " + src + " to " + dest);

        } catch (IOException e) { e.printStackTrace(); }
    }
}

