public class MatrixOperations {
    public static void main(String[] args) {
        int[][] A = {{1,2,3},{4,5,6},{7,8,9}};
        int[][] B = {{9,8,7},{6,5,4},{3,2,1}};
        int     n = 3;
        int[][] sum  = new int[n][n];
        int[][] diff = new int[n][n];

        for (int i = 0; i < n; i++)
            for (int j = 0; j < n; j++) {
                sum[i][j]  = A[i][j] + B[i][j];
                diff[i][j] = A[i][j] - B[i][j];
            }

        System.out.println("Sum Matrix:");
        for (int[] row : sum)  { for (int x : row) System.out.printf("%4d", x); System.out.println(); }

        System.out.println("Difference Matrix:");
        for (int[] row : diff) { for (int x : row) System.out.printf("%4d", x); System.out.println(); }
    }
}

