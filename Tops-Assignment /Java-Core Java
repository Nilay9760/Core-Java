LAB EXERCISE 13c: Inter-Thread Communication (wait/notify)
--------------------------------------------------------------------------------

class SharedResource {
    int data;
    boolean available = false;

    synchronized void produce(int value) throws InterruptedException {
        while (available) wait();  // wait if already produced
        data = value;
        available = true;
        System.out.println("Produced: " + data);
        notify();
    }

    synchronized void consume() throws InterruptedException {
        while (!available) wait();  // wait if nothing produced yet
        System.out.println("Consumed: " + data);
        available = false;
        notify();
    }
}

public class WaitNotifyDemo {
    public static void main(String[] args) {
        SharedResource res = new SharedResource();

        Thread producer = new Thread(() -> {
            try { for(int i=1;i<=5;i++) res.produce(i); }
            catch (InterruptedException e) {}
        });

        Thread consumer = new Thread(() -> {
            try { for(int i=1;i<=5;i++) res.consume(); }
            catch (InterruptedException e) {}
        });

        producer.start();
        consumer.start();
    }
}


